export async function scrapeWikipedia(name) {
  try {
    const searchUrl = `https://en.wikipedia.org/w/api.php?action=query&list=search&srsearch=${encodeURIComponent(name)}%20politician&format=json`;
    const searchResponse = await axios.get(searchUrl);
    
    if (searchResponse.data.query.search.length > 0) {
      const pageId = searchResponse.data.query.search[0].pageid;
      const pageUrl = `https://en.wikipedia.org/w/api.php?action=parse&pageid=${pageId}&format=json&prop=text|images`;
      const pageResponse = await axios.get(pageUrl);
      
      const $ = cheerio.load(pageResponse.data.parse.text['*']);
      
      // Extract basic info
      const fullName = $('h1.firstHeading').text();
      const image = $('.infobox img').first().attr('src');
      const imageUrl = image ? `https:${image}` : null;
      
      return {
        full_name: fullName,
        bio: $('.mw-parser-output p').first().text().substring(0, 500) + '...',
        photo_url: imageUrl
      };
    }
    
    return null;
  } catch (error) {
    console.error('Wikipedia scrape error:', error.message);
    return null;
  }
}

